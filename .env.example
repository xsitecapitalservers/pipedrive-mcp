# ─────────────────────────────────────────────
# Pipedrive MCP Connector — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# ── Pipedrive ──────────────────────────────────
# Your Pipedrive API token.
# Find it: Pipedrive → Settings → Personal preferences → API
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token_here

# ── Microsoft Teams ────────────────────────────
# Incoming Webhook URL for your Teams channel.
# Create one: Teams → Channel → ... → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ── Server ─────────────────────────────────────
# Port the MCP server listens on (default: 3000)
PORT=3000

# A secret token clients must send to authenticate.
# Make this a long random string — e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=change_me_to_a_long_random_secret
